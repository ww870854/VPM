<Window x:Class="VPM.BatchSubfolderSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:VPM"
        xmlns:Language="clr-namespace:VPM.Language;assembly=VPM"
        Title="{Binding [SelectCopiesToKeep], Source={x:Static Language:LanguageManager.Instance}, Mode=OneWay}"
        Width="900" Height="650"
        MinWidth="700" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        ResizeMode="CanResize">

    <Window.Resources>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#3E3E3E"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="RowHeight" Value="32"/>
            <Setter Property="MaxHeight" Value="160"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="#3E3E3E"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2A2A"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#37474F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#424242"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#505050"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="{Binding [ChooseOneCopyPerPackage], Source={x:Static Language:LanguageManager.Instance}, Mode=OneWay}"
                       FontSize="18" FontWeight="Bold"
                       Foreground="#4CAF50" Margin="0,0,0,8"/>
            <TextBlock x:Name="DescriptionText"
                       Text="{Binding [SelectCopiesToKeepDescription], Source={x:Static Language:LanguageManager.Instance}, Mode=OneWay}"
                       FontSize="13" Foreground="#B0B0B0" TextWrapping="Wrap"/>
        </StackPanel>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="PackageGroupsItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,12" Padding="12" Background="#252526" CornerRadius="4"
                                BorderBrush="#3E3E3E" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding PackageName}"
                                           FontWeight="SemiBold" Foreground="#81C784"
                                           FontSize="13" Margin="0,0,0,8"/>
                                <DataGrid ItemsSource="{Binding Instances}"
                                          SelectedItem="{Binding SelectedInstance, Mode=TwoWay}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Location" Width="*" Binding="{Binding RelativeLocation}" IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontFamily" Value="Consolas"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Size" Width="90" Binding="{Binding FileSizeFormatted}" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Modified" Width="130" Binding="{Binding ModifiedDateFormatted}" IsReadOnly="True"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="StatusText" Grid.Column="0"
                       VerticalAlignment="Center" Foreground="#B0B0B0" FontSize="12"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{Binding [KeepSelectedCopies], Source={x:Static Language:LanguageManager.Instance}, Mode=OneWay}"
                        MinWidth="180" Height="40" FontWeight="SemiBold"
                        Background="#4CAF50" Foreground="White"
                        Click="KeepSelected_Click" Margin="0,0,12,0"/>
                <Button Content="{Binding [Cancel], Source={x:Static Language:LanguageManager.Instance}, Mode=OneWay}" MinWidth="100" Height="40"
                        Click="Cancel_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
