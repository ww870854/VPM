<Window x:Class="VPM.ConfirmArchiveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:VPM"
        xmlns:Language="clr-namespace:VPM.Language;assembly=VPM"
        Title="{Binding [ArchiveOldVersions], Source={x:Static Language:LanguageManager.Instance}, Mode=OneWay}"
        Width="900" Height="600"
        MinWidth="500" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="#1E1E1E"
        Foreground="#E0E0E0"
        SizeToContent="Manual">
    <Grid Background="#1E1E1E" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" VerticalAlignment="Center">
            <Ellipse Width="36" Height="36" Fill="#FF9800" StrokeThickness="0" Opacity="0.85"/>
            <TextBlock Text="📦" FontSize="20" FontWeight="Bold" Foreground="#1E1E1E" Margin="-28,0,0,0" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding [ArchiveOldVersions], Source={x:Static Language:LanguageManager.Instance}, Mode=OneWay}" FontSize="18" FontWeight="SemiBold" Margin="16,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <TextBlock x:Name="MessageTextBlock" Grid.Row="2" TextWrapping="Wrap" FontSize="14" Margin="0"/>

        <Border Grid.Row="4" Background="#232323" BorderBrush="#444" BorderThickness="1" CornerRadius="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
                <TextBlock x:Name="PackageListTextBlock" TextWrapping="Wrap" Margin="8" Foreground="#E0E0E0"/>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                <Button x:Name="ArchiveAllButton" Content="{Binding [ArchiveAllOld], Source={x:Static Language:LanguageManager.Instance}, Mode=OneWay}" Click="ArchiveAllButton_Click" 
                        Width="280" Height="40" Margin="0" Padding="12,0" FontSize="13" FontWeight="SemiBold"
                        Foreground="#FFFFFF" Background="#FF6F00" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F57C00"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <StackPanel.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Width" Value="110"/>
                        <Setter Property="Height" Value="40"/>
                        <Setter Property="Margin" Value="8,0,0,0"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Foreground" Value="#FFFFFF"/>
                        <Setter Property="Background" Value="#FF9800"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsDefault" Value="True">
                                <Setter Property="Background" Value="#FB8C00"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F57C00"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Resources>
                <Button x:Name="ArchiveButton" Content="{Binding [ArchiveAll], Source={x:Static Language:LanguageManager.Instance}, Mode=OneWay}" Click="ArchiveButton_Click" IsDefault="True"/>
                <Button x:Name="CancelButton" Content="{Binding [Cancel], Source={x:Static Language:LanguageManager.Instance}, Mode=OneWay}" Click="CancelButton_Click" Background="#424242" Foreground="#E0E0E0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>